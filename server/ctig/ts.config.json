{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/*"],
      "@components/*": ["resources/js/Components/*"],
      "@pages/*": ["resources/js/Pages/*"],
      "@layouts/*": ["resources/js/Layouts/*"],
      "@composables/*": ["resources/js/Composables/*"],
      "@interfaces/*": ["resources/js/Interfaces/*"]
    }
  },
  "include": [
    "resources/js/**/*",
    "resources/js/**/*.vue"
  ]
}